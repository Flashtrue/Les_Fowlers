<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n" />

    <!-- DEBUG dans la console pour tous les packages -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>DEBUG</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- ERROR dans err.log pour les packages contenant ch -->
    <appender name="ERR_FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/err.log</file>
        <append>true</append>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- INFO dans un fichier du jour pour les services -->
    <appender name="SERVICE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/cafheg_%d{yyyy-MM-dd}.log</fileNamePattern>
        </rollingPolicy>
    </appender>

    <!-- Packages ch.* -->
    <logger name="ch" level="DEBUG" additivity="true">
        <appender-ref ref="ERR_FILE" />
    </logger>

    <!-- Packages services de allocations et versements -->
    <logger name="ch.hearc.cafheg.domain.allocations" level="INFO" additivity="true">
        <appender-ref ref="SERVICE_FILE" />
    </logger>

    <logger name="ch.hearc.cafheg.domain.versements" level="INFO" additivity="true">
        <appender-ref ref="SERVICE_FILE" />
    </logger>

    <!-- Tous les packages -->
    <root level="DEBUG">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>